# Better Auth configuration
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET= # Generate a secret key: `bunx --bun @better-auth/cli secret`

# Turso database
TURSO_DATABASE_URL="libsql://your-database.turso.io"
TURSO_DATABASE_AUTH_TOKEN="your-auth-token"

# Admin password for the /credentials management page
ADMIN_PASSWORD=
